#!/usr/bin/env bash
# tg-watchdog — auto-heal a stalled --channels Telegram poller.
# Run by cron every minute. Symptom it fixes: an inbound message gets injected
# into the tmux input box but not auto-submitted, so the poller stops consuming
# and getWebhookInfo's pending_update_count climbs (bot looks dead). If pending
# stays > 0 for 2+ consecutive minutes AND the claude session is IDLE (not
# actively working), press Enter to submit the stuck message so polling resumes.
# No-op while the session is busy (it will poll again when it finishes).
set -u
[ -f /etc/default/tg-watchdog ] && . /etc/default/tg-watchdog
BOT_USER="${BOT_USER:-botuser}"
STATE_DIR="${TELEGRAM_STATE_DIR:-/home/botuser/.claude/channels/telegram}"
FLAG=/tmp/tg-watchdog.count
DEADFLAG=/tmp/tg-watchdog.dead
LOG=/tmp/tg-watchdog.log

# v2: stand down while the entrypoint's startup self-check is actively (re)launching
# the session — otherwise we'd kill the session it's managing mid-boot.
[ -f /tmp/tg-startup.lock ] && exit 0

g() { if [ "$(id -u)" = "0" ] && command -v gosu >/dev/null 2>&1; then gosu "$BOT_USER" "$@"; else "$@"; fi; }

TOK=$(sed -n 's/^TELEGRAM_BOT_TOKEN=//p' "$STATE_DIR/.env" 2>/dev/null | head -1 | tr -d '"'"'"'"'"'"' ')
[ -z "$TOK" ] && exit 0

# v2: a DEAD poller (bun channels server never started / crashed) shows no live
# bot.pid. Sending Enter can't help — the poller isn't running. Require it dead for
# 2 consecutive checks (avoid a transient blip), then kill the session: the
# entrypoint's `tmux attach` exits → PID 1 exits → restart policy respawns the
# container → the LOOPED startup self-check brings the poller back up.
PID="$(cat "$STATE_DIR/bot.pid" 2>/dev/null || true)"
if [ -z "$PID" ] || [ ! -d "/proc/$PID" ]; then
  if g tmux has-session -t claude 2>/dev/null; then
    if [ -f "$DEADFLAG" ]; then
      echo "$(date -u +%FT%TZ) tg-watchdog: poller DEAD 2x (bot.pid='$PID') -> killing claude session (container will respawn)" >> "$LOG"
      g tmux kill-session -t claude 2>/dev/null || true
      rm -f "$DEADFLAG"
    else
      : > "$DEADFLAG"
    fi
  fi
  rm -f "$FLAG"
  exit 0
fi
rm -f "$DEADFLAG"

P=$(curl -fsS --max-time 15 "https://api.telegram.org/bot$TOK/getWebhookInfo" 2>/dev/null | sed -n 's/.*"pending_update_count":\([0-9]*\).*/\1/p')
[ -z "$P" ] && exit 0

# Nothing pending → healthy, reset the stuck counter.
if [ "$P" -eq 0 ] 2>/dev/null; then
  rm -f "$FLAG"
  exit 0
fi

# pending > 0. If the session is actively working, leave it alone — it will poll
# again when done (avoid injecting a stray Enter into a busy TUI).
pane=$(g tmux capture-pane -pt claude 2>/dev/null)
if printf '%s' "$pane" | grep -qiE "esc to interrupt|working|Crafting|Cogitat|Sauté|Simmer|Percolat|Distilling|Ruminat|Brewing|Forging|Herding"; then
  rm -f "$FLAG"
  exit 0
fi

# Idle + pending > 0 → count consecutive stuck minutes; heal on the 2nd.
n=0; [ -f "$FLAG" ] && n=$(cat "$FLAG" 2>/dev/null || echo 0)
case "$n" in ''|*[!0-9]*) n=0;; esac
n=$((n + 1))
if [ "$n" -ge 2 ]; then
  g tmux send-keys -t claude Enter 2>/dev/null
  echo "$(date -u +%FT%TZ) tg-watchdog: pending=$P, session idle ${n}min -> sent Enter to unstick poller" >> "$LOG"
  rm -f "$FLAG"
else
  echo "$n" > "$FLAG"
fi
exit 0
