#!/usr/bin/env bash
# bot-doctor — chẩn đoán sức khoẻ một bot claude-telegram-docker v2.2 (worker mode).
# Dùng:  docker exec <container> bot-doctor
# v2.2 transport = tg-worker.py (không còn tmux / --channels). Check tiến trình
# worker, heartbeat, env quyền, poller drain, locale, base CLAUDE.md, .workspace,
# reminders, login.
set -u
BOT_USER="${BOT_USER:-botuser}"
BOT_HOME="${BOT_HOME:-/home/botuser}"
CFG="${CLAUDE_CONFIG_DIR:-$BOT_HOME/.claude}"
STATE="${TELEGRAM_STATE_DIR:-$CFG/telegram}"
WORK="${WORK_DIR:-$CFG/workspace}"

g() { if [ "$(id -u)" = "0" ] && command -v gosu >/dev/null 2>&1; then gosu "$BOT_USER" "$@"; else "$@"; fi; }
ok()   { printf '  \033[32m[OK]\033[0m   %s\n' "$1"; }
bad()  { printf '  \033[31m[FAIL]\033[0m %s\n         -> %s\n' "$1" "$2"; FAILS=$((FAILS+1)); }
warn() { printf '  \033[33m[WARN]\033[0m %s\n         -> %s\n' "$1" "$2"; }
FAILS=0

echo "==================== bot-doctor (v2.2 worker) ===================="

# 1) worker process alive?
if pgrep -f "tg-worker.py" >/dev/null 2>&1; then
  ok "tg-worker.py đang chạy"
else
  bad "KHÔNG thấy tiến trình tg-worker.py (bot đã chết)" "docker restart <container> ; xem docker logs <container>"
fi

# 2) heartbeat tươi?
HB="$STATE/worker.heartbeat"
if [ -f "$HB" ]; then
  now=$(date +%s); mt=$(stat -c %Y "$HB" 2>/dev/null || echo 0); age=$((now - mt))
  if [ "$age" -le 180 ]; then ok "heartbeat tươi (${age}s trước)"; else bad "heartbeat CŨ (${age}s) — worker kẹt" "docker restart <container>"; fi
else
  warn "chưa có heartbeat ($HB)" "bình thường nếu vừa khởi động; nếu lâu vẫn thiếu -> xem logs"
fi

# 3) quyền: model / permission-mode / allowedTools (từ env)
PM="${TG_WORKER_PERMISSION_MODE:-${PERMISSION_MODE:-auto}}"
AT="${TG_WORKER_ALLOWED_TOOLS:-mcp__mempalace,Read,Grep,Glob,WebFetch,WebSearch (mặc định)}"
ok "permission-mode(env)=$PM  model=${MODEL:-default}"
ok "allowedTools=$AT"

# 4) poller: pending drain?
TOK=$(sed -n 's/^TELEGRAM_BOT_TOKEN=//p' "$STATE/.env" 2>/dev/null | head -1 | tr -d '"'"'"'"'"'"' ')
if [ -n "$TOK" ]; then
  P=$(curl -fsS "https://api.telegram.org/bot$TOK/getWebhookInfo" 2>/dev/null | sed -n 's/.*"pending_update_count":\([0-9]*\).*/\1/p')
  if [ -z "$P" ]; then
    warn "không lấy được pending (mạng/token?)" "kiểm tra kết nối + token"
  elif [ "$P" -gt 0 ] 2>/dev/null; then
    sleep 6
    P2=$(curl -fsS "https://api.telegram.org/bot$TOK/getWebhookInfo" 2>/dev/null | sed -n 's/.*"pending_update_count":\([0-9]*\).*/\1/p')
    if [ "${P2:-1}" -ge "$P" ] 2>/dev/null; then
      warn "pending=$P chưa drain" "worker có thể đang bận 1 turn dài; xem $STATE/worker.log"
    else
      ok "poller: pending đang drain ($P -> $P2)"
    fi
  else
    ok "poller: pending=0 (worker consume tin tốt)"
  fi
else
  bad "không đọc được token ở $STATE/.env" "kiểm tra volume ~/.claude/telegram/.env"
fi

# 5) locale UTF-8
case "${LANG:-}" in
  *UTF-8*|*utf8*) ok "locale UTF-8 ($LANG)";;
  *) warn "locale=${LANG:-chưa set} (không UTF-8)" "recreate từ image mới";;
esac

# 6) base CLAUDE.md + .workspace + reminders
[ -f "$CFG/CLAUDE.md" ] && ok "base CLAUDE.md có ($CFG/CLAUDE.md)" || warn "thiếu base CLAUDE.md" "recreate/pull image mới để seed"
[ -d "$WORK/.workspace" ] && ok ".workspace/ có" || warn "thiếu .workspace/" "recreate/pull image mới"
RC=$(ls "$WORK/reminders"/*.json 2>/dev/null | wc -l | tr -d ' ')
ok "reminders: $RC file (xem: tg-reminder list)"

# 7) login claude
if g env HOME="$BOT_HOME" CLAUDE_CONFIG_DIR="$CFG" claude auth status >/dev/null 2>&1; then
  ok "claude đã đăng nhập (subscription)"
else
  [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ] && ok "claude auth qua CLAUDE_CODE_OAUTH_TOKEN" || bad "claude CHƯA đăng nhập" "docker exec -it -u $BOT_USER <container> claude auth login (hoặc -e CLAUDE_CODE_OAUTH_TOKEN)"
fi

echo "================================================================="
if [ "$FAILS" -eq 0 ]; then echo "Kết quả: OK, không lỗi nghiêm trọng."; else echo "Kết quả: $FAILS lỗi cần xử lý (xem [FAIL] ở trên)."; fi
exit 0
