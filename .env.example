# Copy to .env and fill. .env is gitignored — never commit real secrets.
TELEGRAM_BOT_TOKEN=123456:put-your-botfather-token-here
OWNER_ID=<your-telegram-user-id>

# Auth (recommended, headless — no interactive login). Generate once on any
# machine/container with claude:  docker exec -it <bot> claude setup-token
# then paste the printed token here. Survives volume wipes (lives in .env).
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...

# Optional:
# Permission policy. Unset = claude default (may prompt). For an autonomous bot
# that runs tools without asking, set bypassPermissions (opt in deliberately).
# default | acceptEdits | bypassPermissions | plan
# PERMISSION_MODE=bypassPermissions
# Working dir the bot's claude runs in (file ops land here; pre-trusted).
# WORK_DIR=/working-directory/claude-telegram-bot
# MODEL=claude-sonnet-4-6
# TZ=Asia/Ho_Chi_Minh
# Fallback auth only if `claude setup-token` paste-code doesn't work in-container:
# ANTHROPIC_API_KEY=sk-ant-...
