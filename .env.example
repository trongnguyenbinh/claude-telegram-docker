# Copy to .env and fill. .env is gitignored — never commit real secrets.
# Luồng: docker compose up -d  →  đăng nhập 1 lần (claude auth login)  →  done.
# Mọi cấu hình khác nạp từ file này.

# ===== BẮT BUỘC =====
TELEGRAM_BOT_TOKEN=123456:put-your-botfather-token-here
OWNER_ID=<your-telegram-user-id>

# ===== Auth =====
# Cách CHÍNH: đăng nhập tương tác 1 lần, creds lưu trên volume (/data/.claude),
# sống qua restart — KHÔNG cần nhét gì vào .env:
#   docker exec -it -u botuser <container> claude auth login
# (PHẢI có -u botuser để creds thuộc đúng user bot chạy.)
#
# Cách thay thế (headless, không cần login tương tác) — bỏ comment 1 trong 2:
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...   # tạo bằng: claude setup-token
# ANTHROPIC_API_KEY=sk-ant-...             # trả tiền theo token

# ===== Auto Mode =====
# bypassPermissions = bot TỰ chạy mọi tool không hỏi (container chạy non-root nên
# hết bị chặn). Các mức: default | acceptEdits | bypassPermissions | plan.
PERMISSION_MODE=bypassPermissions

# ===== Tuỳ chọn =====
# MODEL=claude-sonnet-4-6
# TZ=Asia/Ho_Chi_Minh
# WORK_DIR=/working-directory/claude-telegram-bot   # nơi claude chạy (đã pre-trust)
